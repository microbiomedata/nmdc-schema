# local/.env — Environment variables for nmdc-schema development scripts.
#
# NEVER overwrite an existing local/.env with this file — it may contain
# real credentials. Only copy if local/.env does not exist:
#
#   [ ! -f local/.env ] && cp .env.example local/.env
#
# If local/.env already exists, compare keys to see if new variables were added:
#
#   diff <(sed 's/=.*//' .env.example) <(sed 's/=.*//' local/.env)
#
# Scripts load local/.env automatically via python-dotenv.
#   cp local/.env.example local/.env

# --- Ontology registry counts (src/scripts/ontology_registry_counts.py) ---
# Required only for BioPortal counts; OLS/OBO Foundry/semantic-sql work without it.
# Get a key at: https://bioportal.bioontology.org/account
BIOPORTAL_API_KEY=

# --- NCBI Biosample term matching (src/scripts/ncbi_postgres_nmdc_exact_term_matching.py) ---
BIOSAMPLES_RDB_USER=
BIOSAMPLES_RDB_PWD=

# --- MongoDB data dump (nmdc_schema/dump_single_modality.py) ---
# For direct MongoDB access. Open an SSH tunnel to the source if needed.
SOURCE_MONGO_USER=
SOURCE_MONGO_PASS=
SOURCE_MONGO_HOST=
SOURCE_MONGO_PORT=
SOURCE_MONGO_AUTH_SUFFIX=authSource=admin&readPreference=primary&directConnection=true&ssl=false

# --- NEON data retrieval ---
NEON_TOKEN=

# --- NMDC data portal session (rarely needed) ---
DATA_MICROBIOMEDATA_ORG_SESSION_COOKIE=
