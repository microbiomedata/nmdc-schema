%% Derived from src/data/valid/Database-isolate-from-soil-workflow.yaml.
%% Shows every entity and edge asserted by the data file, including the
%% ControlledIdentifiedTermValue wrapper between Strain.classified_as and Taxon.
%% Upstream collection context (FieldResearchSite + CollectingBiosamplesFromSite)
%% is not currently in the data file — omitted here to keep diagram faithful.
flowchart LR
    BSM["Biosample<br/>nmdc:bsm-99-soil001<br/>Anavilhanas soil"]
    ISN["Isolation<br/>nmdc:isnp-99-isol001"]
    OSM1["OrganismSample<br/>nmdc:osm-99-colony01<br/>ICBG1012 colony pick"]
    CULT["Culturing<br/>nmdc:cultp-99-cult001"]
    OSM2["OrganismSample<br/>nmdc:osm-99-culture01<br/>ICBG1012 expanded culture"]
    EXT["Extraction<br/>nmdc:extrp-99-extr001"]
    PSM["ProcessedSample<br/>nmdc:procsm-99-dna001<br/>ICBG1012 extracted DNA"]
    STRN["Strain<br/>nmdc:strn-99-amyco012<br/>Amycolatopsis sp. ICBG1012"]
    CITV["ControlledIdentifiedTermValue<br/>Amycolatopsis [NCBITaxon:1813]"]
    TAX["Taxon<br/>NCBITaxon:1813"]

    ISN -->|has_input| BSM
    ISN -->|has_output| OSM1
    CULT -->|has_input| OSM1
    CULT -->|has_output| OSM2
    EXT -->|has_input| OSM2
    EXT -->|has_output| PSM

    OSM1 -.->|expected_content| STRN
    OSM2 -.->|expected_content| STRN
    STRN -->|classified_as| CITV
    CITV -->|term| TAX

    classDef newPR fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    classDef concrete fill:#fafafa,stroke:#9e9e9e
    class ISN,CULT,OSM1,OSM2,STRN,TAX newPR
    class BSM,EXT,PSM,CITV concrete
