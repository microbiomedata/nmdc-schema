%% Derived from src/data/valid/Database-viral-isolate-with-host.yaml.
%% The Biosample describes the host-culture substrate (E. coli K-12 lysate);
%% the Organism and OrganismSample describe the focal phage (T4).
%% No isolation process is asserted in the data file — BSM and OSM co-exist
%% without an explicit has_input/has_output edge. Host identity is expressed
%% via host_taxid (MIxS slot, ontology-grounded) plus the NMDC-native
%% host_genus/host_species/host_strain free-text slots on the Biosample.
flowchart LR
    BSM["Biosample<br/>nmdc:bsm-99-aqx88e<br/>T4 lysate from E. coli K-12<br/><i>host_genus: Escherichia</i><br/><i>host_species: coli</i><br/><i>host_strain: K-12 MG1655</i>"]
    HTAX["OntologyClass<br/>NCBITaxon:511145<br/>E. coli K-12 MG1655 (host)"]
    OSM["OrganismSample<br/>nmdc:osm-99-vqkvad<br/>T4 phage particles"]
    ORG["Organism<br/>nmdc:orgn-99-pgw8nq<br/>Enterobacteria phage T4"]
    TAX["NcbiTaxon<br/>NCBITaxon:10665"]

    BSM -->|host_taxid| HTAX
    OSM -.->|expected_organism| ORG
    ORG -->|classified_as| TAX

    classDef newPR fill:#e3f2fd,stroke:#1565c0,stroke-width:3px
    classDef concrete fill:#fafafa,stroke:#9e9e9e
    class OSM,ORG,TAX newPR
    class BSM,HTAX concrete
