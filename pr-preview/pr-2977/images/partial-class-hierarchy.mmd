%% Class hierarchy for the isolate-modeling PR (#2977 / #2803).
%% Classes shown are (a) instantiated in src/data/valid/Database-*.yaml
%% examples for this PR, (b) their parents, and (c) a small set of sibling
%% classes whose presence explains modeling decisions (e.g. Taxon follows the
%% FunctionalAnnotationTerm pattern). AttributeValue is a separate top-level
%% root and is NOT a subclass of NamedThing in the schema.
graph BT
    classDef abstract stroke-dasharray:5 5,fill:#fafafa,stroke:#9e9e9e
    classDef concrete fill:#fafafa,stroke:#9e9e9e
    classDef newPR fill:#e3f2fd,stroke:#1565c0,stroke-width:3px

    %% ===== NamedThing tree =====
    NT[NamedThing]:::concrete

    ME[MaterialEntity]:::abstract -->|is_a| NT
    PP[PlannedProcess]:::abstract -->|is_a| NT
    OC[OntologyClass]:::concrete -->|is_a| NT
    IO[InformationObject]:::abstract -->|is_a| NT

    %% --- MaterialEntity branch ---
    Instrument:::concrete -->|is_a| ME
    Organism:::newPR -->|is_a| ME
    Site[Site]:::abstract -->|is_a| ME
    S[Sample]:::abstract -->|is_a| ME

    Strain:::newPR -->|is_a| Organism
    FRS[FieldResearchSite]:::concrete -->|is_a| Site

    Biosample:::concrete -->|is_a| S
    OrganismSample:::newPR -->|is_a| S
    ProcessedSample:::concrete -->|is_a| S

    %% --- PlannedProcess branch ---
    MP[MaterialProcessing]:::abstract -->|is_a| PP
    DEP[DataEmitterProcess]:::abstract -->|is_a| PP
    CBFS[CollectingBiosamplesFromSite]:::concrete -->|is_a| PP

    Isolation:::newPR -->|is_a| MP
    Culturing:::newPR -->|is_a| MP
    Extraction:::concrete -->|is_a| MP
    LibraryPreparation:::concrete -->|is_a| MP

    DataGeneration:::concrete -->|is_a| DEP
    WorkflowExecution:::concrete -->|is_a| DEP

    %% --- OntologyClass branch ---
    Taxon:::newPR -->|is_a| OC
    FAT[FunctionalAnnotationTerm]:::concrete -->|is_a| OC

    %% --- InformationObject branch ---
    DataObject:::concrete -->|is_a| IO

    %% ===== AttributeValue tree (separate root) =====
    AV[AttributeValue]:::abstract

    CITV[ControlledIdentifiedTermValue]:::concrete -->|is_a| AV
    TextValue:::concrete -->|is_a| AV
    TimestampValue:::concrete -->|is_a| AV
